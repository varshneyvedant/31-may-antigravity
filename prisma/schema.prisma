// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

enum Role {
  OWNER
  MANAGER
}

enum TransactionType {
  INCOMING
  OUTGOING
}

enum AttendanceStatus {
  Present
  Absent
  Half_day @map("Half-day")
  Custom
}

enum ScrapType {
  GENERATED
  SOLD
}

enum ExpenseStatus {
  UNPAID
  PAID
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  username String @unique
  password String
  role     Role
}

model PaymentRecord {
  id             String          @id @default(uuid())
  date           DateTime        @default(now())
  amount         Decimal
  type           TransactionType
  customerId     String?
  supplierId     String?
  expenseId      String?
  scrapSaleId    String?
  idempotencyKey String?         @unique
  description    String?

  customer       Customer?       @relation(fields: [customerId], references: [id])
  supplier       Supplier?       @relation(fields: [supplierId], references: [id])
  expense        Expense?        @relation(fields: [expenseId], references: [id])
  scrapSale      ScrapInventory? @relation(fields: [scrapSaleId], references: [id])

  invoicePayments InvoicePayment[]
  billPayments    BillPayment[]

  @@index([date])
  @@index([customerId])
  @@index([supplierId])
}

model InvoicePayment {
  id              String        @id @default(uuid())
  paymentRecordId String
  saleId          String
  amountApplied   Decimal
  
  paymentRecord   PaymentRecord @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
  sale            Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([paymentRecordId])
  @@index([saleId])
}

model BillPayment {
  id              String        @id @default(uuid())
  paymentRecordId String
  purchaseId      String
  amountApplied   Decimal
  
  paymentRecord   PaymentRecord @relation(fields: [paymentRecordId], references: [id], onDelete: Cascade)
  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Cascade)

  @@index([paymentRecordId])
  @@index([purchaseId])
}

model Employee {
  id            String          @id @default(uuid())
  name          String
  role          String // "Manager", "Worker", etc.
  baseSalary    Decimal // Base monthly salary
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  attendances   Attendance[]
  advances      Advance[]
  salaryHistory SalaryHistory[]
}

model SalaryHistory {
  id         String   @id @default(uuid())
  employeeId String
  date       DateTime
  amount     Decimal
  reason     String?
  employee   Employee @relation(fields: [employeeId], references: [id])
}

model Attendance {
  id          String           @id @default(uuid())
  employeeId  String
  date        DateTime
  status      AttendanceStatus
  hoursWorked Decimal?
  employee    Employee         @relation(fields: [employeeId], references: [id])

  @@index([date])
  @@index([employeeId])
}

model Advance {
  id           String             @id @default(uuid())
  employeeId   String
  date         DateTime
  amount       Decimal
  amountRepaid Decimal            @default(0)
  reason       String?
  employee     Employee           @relation(fields: [employeeId], references: [id])
  repayments   AdvanceRepayment[]

  @@index([employeeId])
}

model AdvanceRepayment {
  id        String   @id @default(uuid())
  advanceId String
  date      DateTime @default(now())
  amount    Decimal
  advance   Advance  @relation(fields: [advanceId], references: [id])
}

model Supplier {
  id            String           @id @default(uuid())
  name          String
  contact       String?
  address       String?
  gst           String?
  bankDetails   String?
  creditBalance Decimal          @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  purchases     Purchase[]
  ledgers       SupplierLedger[]
  payments      PaymentRecord[]
}

model Customer {
  id            String           @id @default(uuid())
  name          String
  contact       String?
  address       String?
  gst           String?
  transport     String?
  creditBalance Decimal          @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  sales         Sale[]
  ledgers       CustomerLedger[]
  payments      PaymentRecord[]
}

model Purchase {
  id             String          @id @default(uuid())
  supplierId     String
  date           DateTime
  fullyPaidDate  DateTime?
  qty            Decimal         // Tons of raw copper
  pricePerTon    Decimal
  totalValue     Decimal
  amountPaid     Decimal         @default(0)
  supplier       Supplier        @relation(fields: [supplierId], references: [id])
  inventoryBatch InventoryBatch?
  billPayments   BillPayment[]
  isDeleted      Boolean         @default(false)

  @@index([date])
  @@index([supplierId])
}

model InventoryBatch {
  id           String   @id @default(uuid())
  purchaseId   String   @unique
  date         DateTime
  initialQty   Decimal
  remainingQty Decimal
  pricePerTon  Decimal
  purchase     Purchase @relation(fields: [purchaseId], references: [id])

  @@index([date])
}

model Production {
  id              String   @id @default(uuid())
  date            DateTime
  rawCopperUsed   Decimal // Tons
  productCategory String // "CC Wires", "Submersible Winding Wire"
  brand           String? // e.g. "Poly Vansh", "Poly Lifeline"
  wireType        String // e.g., "1mm", "2mm"
  wireProduced    Decimal // Tons
  scrapGenerated  Decimal  @default(0) // Automatically tracked difference (rawUsed - wireProduced)
  isDeleted       Boolean  @default(false)
  finishedGoodsBatch FinishedGoodsBatch?

  @@index([date])
}

model FinishedGoodsBatch {
  id              String        @id @default(uuid())
  productionId    String        @unique
  date            DateTime
  productCategory String
  brand           String?
  wireType        String
  initialQty      Decimal
  remainingQty    Decimal
  costPerTon      Decimal       // Exact FIFO cost inherited from raw copper consumed
  
  production      Production    @relation(fields: [productionId], references: [id])

  @@index([date])
}

model ScrapInventory {
  id        String    @id @default(uuid())
  date      DateTime  @default(now())
  type      ScrapType
  qty       Decimal // Tons
  revenue   Decimal   @default(0) // Money earned if sold
  isDeleted Boolean   @default(false)
  
  payments  PaymentRecord[]
}

model Sale {
  id              String           @id @default(uuid())
  customerId      String
  date            DateTime
  fullyPaidDate   DateTime?
  totalValue      Decimal
  amountPaid      Decimal          @default(0)
  customer        Customer         @relation(fields: [customerId], references: [id])
  items           SaleItem[]
  invoicePayments InvoicePayment[]
  isDeleted       Boolean          @default(false)

  @@index([date])
  @@index([customerId])
}

model SaleItem {
  id                  String  @id @default(uuid())
  saleId              String
  productCategory     String // "CC Wires", "Submersible Winding Wire", "Raw Copper Bundle"
  brand               String? // Optional for raw copper
  wireType            String? // Optional for raw copper
  qty                 Decimal // Tons
  pricePerTon         Decimal
  totalValue          Decimal
  rawCopperCostAtSale Decimal @default(0) // The exact FIFO cost of raw copper per ton on the day this was sold. Essential for exact profit calculations.
  sale                Sale    @relation(fields: [saleId], references: [id])
}

model Expense {
  id           String        @id @default(uuid())
  date         DateTime
  category     String // "Electricity", "Rent", "Maintenance", "Water", "Other"
  amount       Decimal
  description  String?
  expenseMonth String? // e.g. "January 2024"
  status       ExpenseStatus @default(UNPAID)
  isDeleted    Boolean       @default(false)
  
  payments     PaymentRecord[]
}

model MarketPrice {
  id    String   @id @default(uuid())
  date  DateTime
  price Decimal // Price per Ton of raw copper
}

model SupplierLedger {
  id          String   @id @default(uuid())
  supplierId  String
  date        DateTime
  amount      Decimal // Positive means we owe them (Invoice), Negative means we paid them (Payment)
  description String?
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  isDeleted   Boolean  @default(false)

  @@index([supplierId])
  @@index([date])
}

model CustomerLedger {
  id          String   @id @default(uuid())
  customerId  String
  date        DateTime
  amount      Decimal // Positive means they owe us (Invoice), Negative means they paid us (Payment)
  description String?
  customer    Customer @relation(fields: [customerId], references: [id])
  isDeleted   Boolean  @default(false)

  @@index([customerId])
  @@index([date])
}

model AuditLog {
  id          String   @id @default(uuid())
  date        DateTime @default(now())
  user        String // "manager" or "owner"
  action      String // "CREATE", "UPDATE", "DELETE"
  module      String // "Sales", "Purchases", "Production", etc.
  description String // Human readable summary
  details     String? // JSON string of old/new values
}
